---
import '../styles/global.css'

interface Props {
  title: string
  description?: string
  activePage?: 'top-50' | 'a-plus' | 'albums'
}

const { title, description = 'Five hundred albums. Mine.', activePage } = Astro.props
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://fivehundred.danieltovar.dev/og-image.png" />
  <meta property="og:url" content="https://fivehundred.danieltovar.dev" />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content="https://fivehundred.danieltovar.dev/og-image.png" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=DM+Sans:ital,wght@0,400;0,500;0,700;1,400&display=swap" rel="stylesheet" />
</head>
<body>
  <!-- Registration marks -->
  <div class="reg tl"><div class="reg-cross"></div></div>
  <div class="reg tr"><div class="reg-cross"></div></div>
  <div class="reg bl"><div class="reg-cross"></div></div>
  <div class="reg br"><div class="reg-cross"></div></div>

  <div class="wrap">
    <nav class="site-nav">
      <a href="/" class="site-wordmark">
        <span>#500</span>Five Hundred
      </a>
      <ul class="nav-links">
        <li><a href="/top-50" class={activePage === 'top-50' ? 'active' : ''}>Top 50</a></li>
        <li><a href="/a-plus" class={activePage === 'a-plus' ? 'active' : ''}>A-Plus</a></li>
        <li><a href="/albums" class={activePage === 'albums' ? 'active' : ''}>Albums</a></li>
      </ul>
    </nav>

    <slot />

    <footer class="site-footer">
      <p class="footer-text">
        Five Hundred
        <span class="footer-dot"></span>
        A Digital Record Collection
      </p>
    </footer>
  </div>
</body>
</html>
