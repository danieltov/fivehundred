---
interface Props {
  covers: string[] // 6 cover art URLs
}
const { covers } = Astro.props
const labels = ['c1','c2','c3','c4','c5','c6']
---

<div class="cover-collage">
  <div class="collage-bg-circle cb1"></div>
  <div class="collage-bg-circle cb2"></div>
  {covers.slice(0,6).map((src, i) => (
    <div class={`collage-cover ${labels[i]}`}>
      <img src={src} alt="" aria-hidden="true" />
    </div>
  ))}
  <div class="halftone-strip"></div>
</div>

<style>
  .cover-collage { position: relative; height: 480px; width: 420px; }

  .collage-cover {
    position: absolute;
    border: 3px solid var(--black);
    overflow: hidden;
    transition: transform 0.3s ease;
  }
  .collage-cover img {
    display: block; width: 100%; height: 100%;
    object-fit: cover;
    mix-blend-mode: multiply;
  }
  .collage-cover::before {
    content: '';
    position: absolute;
    top: 4px; left: 4px;
    width: 100%; height: 100%;
    z-index: -1;
  }
  .c1 { width: 220px; height: 220px; top: 0; left: 20px; transform: rotate(-2deg); z-index: 5; }
  .c1::before { background: var(--coral); }
  .c2 { width: 190px; height: 190px; top: 30px; left: 180px; transform: rotate(1.5deg); z-index: 4; }
  .c2::before { background: var(--teal); }
  .c3 { width: 200px; height: 200px; top: 185px; left: 0; transform: rotate(1deg); z-index: 3; }
  .c3::before { background: var(--yellow); }
  .c4 { width: 180px; height: 180px; top: 200px; left: 170px; transform: rotate(-1.5deg); z-index: 6; }
  .c4::before { background: var(--blue); }
  .c5 { width: 160px; height: 160px; top: 300px; left: 60px; transform: rotate(2deg); z-index: 7; }
  .c5::before { background: var(--pink); }
  .c6 { width: 170px; height: 170px; top: 290px; left: 220px; transform: rotate(-0.8deg); z-index: 2; }
  .c6::before { background: var(--coral); }

  .collage-bg-circle {
    position: absolute; border-radius: 50%;
    mix-blend-mode: multiply; pointer-events: none;
  }
  .cb1 { width: 360px; height: 360px; top: -30px; left: -10px; background: var(--yellow); opacity: 0.35; }
  .cb2 { width: 280px; height: 280px; top: 140px; left: 100px; background: var(--teal); opacity: 0.2; }

  .halftone-strip {
    position: absolute; bottom: 0; left: 0;
    width: 100%; height: 80px;
    background-image: radial-gradient(circle, var(--black) 1.5px, transparent 1.5px);
    background-size: 8px 8px;
    opacity: 0.06; pointer-events: none;
  }
</style>
