---
import Layout from '../components/Layout.astro'
import type { AlbumsJson, Album } from '../types/album'
import albumsData from '../../data/albums.json'

const { albums } = albumsData as AlbumsJson

const aplusAlbums: Album[] = albums
  .filter(a => a.isAPlus)

const now = new Date()
const newThisMonth: Album[] = aplusAlbums.filter(a => {
  if (!a.createdAt) return false
  const d = new Date(a.createdAt)
  return d.getMonth() === now.getMonth() && d.getFullYear() === now.getFullYear()
})
const monthLabel = now.toLocaleDateString('en-US', { month: 'long', year: 'numeric' }).toUpperCase()
---

<Layout title="A-Plus — Five Hundred" activePage="a-plus">
  <header class="page-hero">
    <div class="hero-grade">
      <span class="hero-grade-text">A+</span>
    </div>
    <div class="hero-right">
      <div class="hero-label">The Ones</div>
      <h1 class="hero-title">The near-perfect ones. The ones where repeated listens kept paying off.</h1>
      <p class="hero-desc">
        These are the albums I kept going back to even when I had four hundred and fifty others I hadn't gotten to yet.
        <em>That's the whole test.</em>
      </p>
    </div>
  </header>

  <div class="count-strip">
    <div class="count-item">
      <span class="count-num">{aplusAlbums.length}</span>
      <span class="count-label">A+ Records</span>
    </div>
    <div class="count-item">
      <span class="count-num">69</span>
      <span class="count-label">Years of Music</span>
    </div>
    <div class="count-item">
      <span class="count-num">∞</span>
      <span class="count-label">Return Trips</span>
    </div>
  </div>

  {newThisMonth.length > 0 && (
    <section class="fresh-band">
      <div class="fresh-header">
        <div class="fresh-label">
          <span class="fresh-dot" aria-hidden="true"></span>
          New This Month
        </div>
        <div class="fresh-month">{monthLabel}</div>
      </div>
      <div class="fresh-grid">
        {newThisMonth.map((album, i) => {
          const year = new Date(album.releaseDate).getFullYear()
          return (
            <a
              href={`/album/${album.slug}`}
              class="fcard"
              style={`--stagger: ${i}`}
            >
              <div class="fcard-cover">
                <img src={album.coverArt} alt={album.title} loading="eager" />
                <div class="fcard-stamp" aria-hidden="true">Just Added</div>
              </div>
              <div class="fcard-info">
                <div class="fcard-title">{album.title}</div>
                <div class="fcard-artist">{album.artist[0]?.name} · {year}</div>
              </div>
            </a>
          )
        })}
      </div>
    </section>
  )}

  <div class="aplus-grid">
    {aplusAlbums.map(album => {
      const year = new Date(album.releaseDate).getFullYear()
      const topDescriptors = album.descriptors.slice(0, 3)
      return (
        <a href={`/album/${album.slug}`} class="acard">
          <div class="acard-cover">
            <img src={album.coverArt} alt={album.title} loading="lazy" />
            {album.topRanking !== null && <div class="top50-dot"></div>}
          </div>
          <div class="acard-info">
            <div class="acard-title">{album.title}</div>
            <div class="acard-artist">{album.artist[0]?.name} · {year}</div>
            <div class="acard-tags">
              {topDescriptors.map(d => <span class="tag">{d.name}</span>)}
            </div>
          </div>
        </a>
      )
    })}
  </div>
</Layout>

<style>
  /* HERO HEADER */
  .page-hero {
    padding: 56px 0 0;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 48px;
    align-items: center;
    position: relative;
    overflow: hidden;
  }
  .page-hero::before {
    content: ''; position: absolute; top: -80px; right: -120px;
    width: 480px; height: 480px; background: var(--coral); border-radius: 50%;
    opacity: 0.18; mix-blend-mode: multiply; pointer-events: none;
  }
  .page-hero::after {
    content: ''; position: absolute; top: 20px; right: 40px;
    width: 320px; height: 320px; background: var(--yellow); border-radius: 50%;
    opacity: 0.3; mix-blend-mode: multiply; pointer-events: none;
  }
  @media (max-width: 680px) {
    .page-hero { grid-template-columns: 1fr; gap: 24px; }
  }

  .hero-grade { position: relative; z-index: 2; line-height: 1; user-select: none; }
  .hero-grade-text {
    font-family: var(--mono); font-weight: 700;
    font-size: clamp(6rem, 15vw, 11rem);
    letter-spacing: -0.05em; color: var(--black); display: block; position: relative;
  }
  .hero-grade-text::before {
    content: 'A+'; position: absolute; top: 0; left: 0;
    color: var(--coral); transform: translate(-5px, 5px);
    opacity: 0.55; mix-blend-mode: multiply;
  }
  .hero-grade-text::after {
    content: 'A+'; position: absolute; top: 0; left: 0;
    color: var(--teal); transform: translate(5px, -4px);
    opacity: 0.55; mix-blend-mode: multiply;
  }

  .hero-right { position: relative; z-index: 2; padding-bottom: 16px; }
  .hero-label {
    font-family: var(--mono); font-size: 0.65rem; text-transform: uppercase;
    letter-spacing: 0.2em; color: var(--coral); display: inline-block;
    padding: 3px 10px; border: 2px solid var(--coral); margin-bottom: 20px;
  }
  .hero-title { font-family: var(--mono); font-weight: 700; font-size: 1.8rem; line-height: 1.15; margin-bottom: 16px; }
  .hero-desc { font-family: var(--sans); font-size: 1rem; line-height: 1.75; max-width: 46ch; opacity: 0.75; }
  .hero-desc em { font-style: normal; font-weight: 700; color: var(--black); opacity: 1; }

  /* COUNT STRIP */
  .count-strip {
    display: flex; align-items: center;
    margin: 40px 0 0;
    border-top: 2px solid var(--black);
    border-bottom: 2px solid var(--black);
  }
  .count-item {
    padding: 14px 20px; border-right: 2px solid var(--black);
    font-family: var(--mono);
  }
  .count-item:last-child { border-right: none; }
  .count-num { font-weight: 700; font-size: 1.4rem; line-height: 1; display: block; margin-bottom: 2px; }
  .count-label { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.12em; opacity: 0.4; }
  .count-item:nth-child(1) .count-num { color: var(--coral); }
  .count-item:nth-child(2) .count-num { color: var(--teal); }
  .count-item:nth-child(3) .count-num { color: var(--blue); }

  /* FRESH BAND — NEW THIS MONTH */
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.7); }
  }
  @keyframes fresh-in {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .fresh-band {
    background: var(--black);
    margin: 0;
    padding: 36px 0 48px;
    border-top: 3px solid var(--black);
  }

  .fresh-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 28px;
    border-bottom: 1px solid rgba(253,246,227,0.1);
    margin-bottom: 28px;
  }
  .fresh-label {
    font-family: var(--mono);
    font-weight: 700;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--coral);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .fresh-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    background: var(--coral);
    border-radius: 50%;
    flex-shrink: 0;
    animation: pulse-dot 2s ease-in-out infinite;
  }
  .fresh-month {
    font-family: var(--mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--cream);
    opacity: 0.25;
  }

  .fresh-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }
  @media (max-width: 860px) { .fresh-grid { grid-template-columns: repeat(2, 1fr); } }

  .fcard {
    display: block;
    text-decoration: none;
    color: var(--cream);
    border: 2px solid rgba(253,246,227,0.08);
    position: relative;
    transition: border-color 0.2s ease, transform 0.2s ease;
    animation: fresh-in 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: calc(var(--stagger) * 90ms);
  }
  .fcard:hover {
    border-color: rgba(253,246,227,0.28);
    transform: translateY(-4px);
  }

  .fcard-cover {
    aspect-ratio: 1;
    overflow: hidden;
    position: relative;
  }
  .fcard-cover::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--coral);
    z-index: 2;
  }
  .fcard-cover img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: contrast(1.05) saturate(0.9);
    transition: transform 0.4s ease, filter 0.4s ease;
  }
  .fcard:hover .fcard-cover img {
    transform: scale(1.04);
    filter: contrast(1.1) saturate(1);
  }
  .fcard-cover::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(0,0,0,0.15) 1px, transparent 1px);
    background-size: 3px 3px;
    pointer-events: none;
    z-index: 1;
  }

  .fcard-stamp {
    position: absolute;
    bottom: 10px;
    left: 10px;
    z-index: 3;
    font-family: var(--mono);
    font-weight: 700;
    font-size: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--black);
    background: var(--yellow);
    padding: 3px 8px;
    line-height: 1.6;
  }

  .fcard-info {
    padding: 14px 14px 16px;
    background: var(--black);
    border-top: 1px solid rgba(253,246,227,0.07);
  }
  .fcard-title {
    font-family: var(--mono);
    font-weight: 700;
    font-size: 0.8rem;
    line-height: 1.3;
    color: var(--cream);
    margin-bottom: 4px;
  }
  .fcard-artist {
    font-family: var(--mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--cream);
    opacity: 0.35;
  }

  /* GRID */
  .aplus-grid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 16px; padding: 48px 0 80px;
  }
  @media (max-width: 860px) { .aplus-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 580px) { .aplus-grid { grid-template-columns: repeat(2, 1fr); } }

  /* CARDS */
  .acard {
    background: var(--cream); border: 3px solid var(--black);
    position: relative; transition: transform 0.2s ease;
    text-decoration: none; color: var(--black);
  }
  .acard::before {
    content: ''; position: absolute; top: 5px; left: 5px;
    width: 100%; height: 100%; z-index: -1;
    transition: top 0.2s, left 0.2s;
  }
  .acard:hover { transform: translate(-3px, -3px); }
  .acard:hover::before { top: 8px; left: 8px; }
  .acard:nth-child(5n+1)::before { background: var(--coral); }
  .acard:nth-child(5n+2)::before { background: var(--teal); }
  .acard:nth-child(5n+3)::before { background: var(--yellow); }
  .acard:nth-child(5n+4)::before { background: var(--blue); }
  .acard:nth-child(5n+0)::before { background: var(--pink); }

  .acard-cover { aspect-ratio: 1; overflow: hidden; position: relative; }
  .acard-cover img { display: block; width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease; }
  .acard:hover .acard-cover img { transform: scale(1.03); }
  .acard-cover::after {
    content: ''; position: absolute; inset: 0;
    background-image: radial-gradient(circle, rgba(0,0,0,0.09) 1px, transparent 1px);
    background-size: 4px 4px; pointer-events: none;
  }

  .top50-dot {
    position: absolute; top: 7px; right: 7px; z-index: 2;
    width: 20px; height: 20px;
    background: var(--coral); border: 2px solid var(--black);
    display: flex; align-items: center; justify-content: center;
    pointer-events: none;
  }
  .top50-dot::before { content: '★'; font-size: 0.5rem; color: var(--cream); line-height: 1; }
  .top50-dot::after {
    content: ''; position: absolute; top: 2px; left: 2px;
    width: 100%; height: 100%; background: var(--yellow); z-index: -1; mix-blend-mode: multiply;
  }

  .acard-info { padding: 14px 16px 16px; }
  .acard-title { font-family: var(--mono); font-weight: 700; font-size: 0.78rem; line-height: 1.3; margin-bottom: 3px; }
  .acard-artist { font-family: var(--mono); font-size: 0.65rem; opacity: 0.5; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 10px; }
  .acard-tags { display: flex; gap: 4px; flex-wrap: wrap; }
  .tag {
    font-family: var(--mono); font-size: 0.55rem; padding: 2px 7px;
    text-transform: uppercase; letter-spacing: 0.06em;
    border: 1.5px solid; background: var(--cream); line-height: 1.6;
  }
  .acard:nth-child(5n+1) .tag { border-color: var(--coral); color: var(--coral); }
  .acard:nth-child(5n+2) .tag { border-color: var(--teal); color: var(--teal); }
  .acard:nth-child(5n+3) .tag { border-color: var(--black); color: var(--black); opacity: 0.65; }
  .acard:nth-child(5n+4) .tag { border-color: var(--blue); color: var(--blue); }
  .acard:nth-child(5n+0) .tag { border-color: var(--pink); color: var(--pink); }
</style>
